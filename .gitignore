# ===== Node / JS（将来 npm 依存を追加した場合に備えて）=====
node_modules/
dist/
build/
.cache/
*.log

# ===== 検証用音声サンプル（フリー音源はライセンス管理のためコミットしない）=====
test-samples/

# ===== ローカルHTTPS用の自己署名証明書（秘密鍵を含むためコミットしない）=====
.certs/

# ===== UIデザイン相談用の参考画像（成果物ではない。実際に使う素材は img/ にコピー済み）=====
d/

# ===== 環境変数・機密（git追跡を必ず止める＝必須）=====
.env
.env.*
# 共有用テンプレだけは追跡する（!行にインラインコメントを付けると無効化されるため、コメントは必ず別行に書く）
!.env.example
